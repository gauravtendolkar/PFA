{
  "name": "pfa",
  "version": "0.1.0",
  "description": "Personal Finance Agent — on-device AI agent for personal finance",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently -n llm,agent,client -c blue,green,yellow \"npm run start:llm\" \"npm run start:agent\" \"npm run start:client\"",
    "dev:no-llm": "concurrently -n agent,client -c green,yellow \"npm run start:agent\" \"npm run start:client\"",
    "start": "node dist/index.js",
    "start:llm": "bash scripts/start-llm.sh",
    "start:agent": "tsx src/agent/server.ts",
    "start:client": "cd client && npx vite --port 5173",
    "setup": "tsx scripts/setup.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "plaid:link": "tsx src/plaid/link-cli.ts",
    "plaid:sync": "tsx src/plaid/sync.ts",
    "test": "vitest run",
    "agent": "tsx src/agent/cli.ts"
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "plaid": "^41.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "vitest": "^4.1.1"
  }
}
